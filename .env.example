# ─────────────────────────────────────────────────
#  JanSeva — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────

# ── Groq AI (required) ────────────────────────────
VITE_GROQ_API_KEY=your_groq_api_key_here
# ── Maps (optional — default is free Leaflet/OSM) ─
# VITE_MAPBOX_TOKEN=pk.xxxxxxxxxxxxxxxxxxxxxxxx
VITE_MAP_PROVIDER=leaflet

# ── Frontend API base (default: /api via Vite proxy)
# VITE_API_BASE_URL=/api

# ── Cloudinary (optional — for production uploads) ─
# VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name

# ─────────────────────────────────────────────────
#  Backend (.env in /backend or root)
# ─────────────────────────────────────────────────

# ── Database ──────────────────────────────────────
DATABASE_URL=postgresql://postgres@localhost:5432/janseva

# ── JWT ───────────────────────────────────────────
JWT_SECRET=janseva_super_secret_key_2026_abc123xyz
JWT_EXPIRES_IN=7d

# ── Groq (server-side) ────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
# ── Cloudinary ────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Email (optional) ──────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password

# ── Server ────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
