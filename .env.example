# ─────────────────────────────────────────────────
#  JanSeva — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────

# ── Maps (optional — default is free Leaflet/OSM) ─
# VITE_MAPBOX_TOKEN=pk.xxxxxxxxxxxxxxxxxxxxxxxx
VITE_MAP_PROVIDER=leaflet

# ── Frontend API base (default: /api via Vite proxy)
# VITE_API_BASE_URL=/api

# ── Cloudinary (optional — for production uploads) ─
# VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name

# ─────────────────────────────────────────────────
#  Backend (.env in /backend or root)
# ─────────────────────────────────────────────────

# ── Database ──────────────────────────────────────
# Local development example:
# DATABASE_URL=postgresql://postgres@localhost:5432/janseva
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# ── JWT ───────────────────────────────────────────
# Generate a long random value for each environment.
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# ── AI reasoning (server-side only) ───────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GROQ_API_KEY=your_groq_api_key_here
# ── Cloudinary ────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Email (optional) ──────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password

# ── Server ────────────────────────────────────────
PORT=3001
NODE_ENV=development
# Optional comma-separated CORS allowlist for separate frontend deployments.
# Leave unset when frontend and backend are served by the same Cloud Run service.
# Local development example:
# FRONTEND_URL=http://localhost:5173
