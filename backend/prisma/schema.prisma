// JanSeva — Prisma schema (PostgreSQL)
// Run: npx prisma migrate dev --name init

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum Category {
  Pothole
  Streetlight
  WaterLeak
  WasteDump
  Sewage
  RoadDamage
  ParkIssue
  Other
}

enum Severity {
  Low
  Medium
  High
  Critical
}

enum Status {
  Reported
  Verified
  AwaitingAssignment
  FlaggedFalse
  Assigned
  Accepted
  InProgress
  Completed
  NeedsVerification
  Rejected
  Resolved
  Closed
}

enum Role {
  Citizen
  Moderator
  Authority
  Admin
}

// ── Models ───────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  citizenId    String    @unique
  name         String
  email        String    @unique
  password     String
  role         Role      @default(Citizen)
  ward         String?
  avatarUrl    String?
  xp              Int       @default(0)
  level           Int       @default(1)
  badges          String[]
  reportStreak    Int       @default(0)
  activeCharacter String    @default("male-0-explorer")
  suspendedUntil  DateTime?

  issues       Issue[]
  comments     Comment[]

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([email])
  @@index([xp(sort: Desc)])
  @@index([citizenId])
}

model Issue {
  id           String    @id @default(cuid())
  title        String
  description  String?
  category     Category
  severity     Severity  @default(Medium)
  status       Status    @default(Reported)

  latitude     Float
  longitude    Float
  address      String?
  zone         String?

  mediaUrls    String[]
  isAnonymous  Boolean   @default(false)

  reporterId   String?
  reporter     User?     @relation(fields: [reporterId], references: [id], onDelete: SetNull)

  upvotes      Int       @default(0)
  verifiedBy   String[]
  followedBy   String[]

  duplicateOf  String?
  duplicateConfidence Float?

  // AI metadata
  aiCategory              String?
  aiConfidence            Float?
  aiSeverity              String?
  estimatedResolutionDays Int?
  resolutionConfidence    Float?
  resolutionReason        String?
  department              String?
  departmentConfidence    Float?
  departmentReason        String?
  priorityScore           Int?
  priorityLabel           String?
  priorityReason          String?
  citizenGuidance         Json?
  authoritySummary        String?
  aiNotifications         Json?
  workflowRecommendation  Json?
  communityInsight        Json?
  heatmapInsight          Json?
  aiModelUsed             String?
  aiAnalyzedAt            DateTime?
  aiFailureReason         String?

  assignedTo              String?
  wardFlagNote            String?
  completionNotes         String?
  completionPhotos        String[]
  internalNotes           InternalNote[]

  comments     Comment[]
  timeline     Timeline[]

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status])
  @@index([category])
  @@index([zone])
  @@index([priorityScore(sort: Desc)])
  @@index([latitude, longitude])
  @@index([createdAt(sort: Desc)])
}

model InternalNote {
  id         String   @id @default(cuid())
  issueId    String
  issue      Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  authorId   String
  authorName String
  content    String
  createdAt  DateTime @default(now())
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  sentiment String?

  issueId   String
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)

  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([issueId])
}

model Timeline {
  id        String   @id @default(cuid())
  event     String
  actor     String
  actorRole Role
  note      String?
  mediaUrl  String?

  issueId   String
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([issueId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  issueId   String?
  type      String
  read      Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
}

model Mission {
  id          String   @id @default(cuid())
  userId      String
  date        String   // YYYY-MM-DD
  category    Category
  title       String
  description String
  xpReward    Int      @default(30)
  completed   Boolean  @default(false)
  completedAt DateTime?

  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([date])
  @@unique([userId, date, category])
}
